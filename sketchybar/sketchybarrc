#!/bin/bash
# ── Sketchybar Configuration ──────────────────────────────────────────
#
# Split by responsibility:
#   defaults.sh    — bar appearance + default item styles
#   workspaces.sh  — aerospace workspace items
#   left.sh        — front app, agent monitor
#   right.sh       — volume, battery, ip, date, week, time
#

PLUGIN_DIR="$CONFIG_DIR/plugins"

source "$CONFIG_DIR/defaults.sh"
source "$CONFIG_DIR/workspaces.sh"
source "$CONFIG_DIR/left.sh"
source "$CONFIG_DIR/right.sh"

# Force all scripts to run the first time.
sketchybar --update
